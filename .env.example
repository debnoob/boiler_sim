# =========================================================================
# NEXUS OS — Environment Variables Example
# Copy this file to '.env' and fill in your actual credentials.
# Do NOT commit your actual '.env' file to Git!
# =========================================================================

# --- Qdrant Vector Database (for RAG Server) ---
# For Qdrant Cloud: URL starts with https:// and needs an API key
# For local Qdrant: URL is typically http://localhost:6333 and no key is needed
QDRANT_URL="https://your-qdrant-cluster-url.aws.cloud.qdrant.io"
QDRANT_API_KEY="your-qdrant-api-key-here"

# --- Ollama Configuration (Local LLM and Embeddings) ---
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="my-boilerSim3:latest"
EMBED_MODEL="nomic-embed-text"

# --- Groq Cloud API (Optional fallback LLM backend) ---
GROQ_API_KEY="gsk_your_groq_api_key_here"

# --- Services Configuration ---
RAG_SERVER_URL="http://localhost:8001"
